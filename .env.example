# phpBB MCP server configuration

# Required: the forum's base URL (no trailing slash needed).
PHPBB_BASE_URL=https://forum.example.com

# Optional: display name shown in tool descriptions / server metadata.
# Defaults to the base URL's hostname when unset.
PHPBB_SITE_NAME=Example Forum

# Optional: forum account, only needed for the login-gated tools
# (my_notifications / my_messages). Many boards block automated login.
PHPBB_USERNAME=
PHPBB_PASSWORD=

# Optional: page sizes, if your board doesn't use the phpBB default of 25.
# PHPBB_POSTS_PER_PAGE=25
# PHPBB_TOPICS_PER_PAGE=25

# Optional: path to a custom forum_guide knowledge-base file. Falls back to the
# KNOWLEDGE.md that ships with the server when unset.
# PHPBB_GUIDE_PATH=./KNOWLEDGE.md
